@Library('shared-library') _

pipeline {
    agent any

    options {
        buildDiscarder(logRotator(
            numToKeepStr: '20',
            daysToKeepStr: '30'
        ))

        disableConcurrentBuilds()
        timestamps()

        timeout(
            time: 30,
            unit: 'MINUTES'
        )
    }

    parameters {
        string(
            name: 'IMAGE_TAG',
            defaultValue: 'latest',
            description: 'Docker image tag'
        )
    }

    environment {
        APP_NAME = 'sample-application'

        GIT_URL = 'https://github.com/username/sample-application.git'
        GIT_CREDENTIALS = 'github_id'
        DOCKER_CREDENTIALS = 'docker_cred_id'
    }

    stages {

        stage('Clean Workspace') {
            steps {
                cleanWs()
            }
        }

        stage('Checkout Code') {
            steps {
                gitCheckout(
                    giturl: env.GIT_URL,
                    credentialsId: env.GIT_CREDENTIALS,
                    branch: '*/development'
                )
            }
        }

        stage('Build Docker') {
            steps {
                script {
                    IMAGE_NAME = "thanikai1/${env.APP_NAME}:${params.IMAGE_TAG}"
                    dockerBuild(IMAGE_NAME)
                }
            }
        }

        stage('Docker Login') {
            steps {
                dockerLogin(env.DOCKER_CREDENTIALS)
            }
        }

        stage('Docker Push') {
            steps {
                script {
                    IMAGE_NAME = "thanikai1/${env.APP_NAME}:${params.IMAGE_TAG}"
                    dockerPush(IMAGE_NAME)
                }
            }
        }

        stage('Deploy Container') {
            steps {
                deployApp()
            }
        }

        stage('Docker Cleanup') {
            steps {
                cleanUp()
            }
        }
    }

    post {
        success {
            echo 'Pipeline completed successfully'
        }

        failure {
            echo 'Pipeline failed'
        }

        always {
            cleanWs()
        }
    }
}
