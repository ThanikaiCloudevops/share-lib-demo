@Library('shared-library') _
pipeline {
    agent any 

    options {
        buildDiscarder(logRotator(
            numToKeepStr: '20',
            daysToKeepStr: '30'
        ))

        disableConcurrentBuilds()
        timestamps()
        // ansiColor('xterm')

        timeout(
            time: 30,
            unit: 'MINUTES'
        )
    }

    parameters {
        string(
            name: 'IMAGE_TAG',
            defaultValue: 'latest',
            description: 'Image tag to build'
        )
    }
    environment {
        APP_NAME = 'sample-application'
        IMAGE_NAME= 'thanikai1/${APP_NAME}:${params.IMAGE_TAG}'
        GIT_URL = 
        GIT_CREDENTAILS =
        DOCKER_CREDENTIALS =
    }
    stages {

        stage('Clean Workspace') {
            steps {
                cleanWs()
            }
        }

        stage('Checkout Code') {
            steps {
                gitCheckout(
                    giturl: env.GIT_URL ,
                    credentialsId: env.GIT_CREDENTAILS,
                    branch: '*/development'
                )
            }
        }

        stage('Build Docker') {
            steps {
                sh """
                    docker build -t ${FULL_IMAGE_NAME} .
                """
            }
        }

        stage('Docker Login') {
            steps {
                withCredentials([
                    usernamePassword(
                        credentialsId: env.DOCKER_CREDENTIALS_ID,
                        usernameVariable: 'DOCKER_USER',
                        passwordVariable: 'DOCKER_PASS'
                    )
                ]) {
                    sh """
                        echo "\$DOCKER_PASS" | docker login \
                        -u "\$DOCKER_USER" \
                        --password-stdin
                    """
                }
            }
        }

        stage('Docker Push') {
            steps {
                sh """
                    docker push ${FULL_IMAGE_NAME}
                """
            }
        }

        stage('Remove Existing Container') {
            steps {
                sh """
                    docker rm -f ${CONTAINER_NAME} || true
                """
            }
        }

        stage('Deploy Container') {
            steps {
                sh """
                    docker run -d \
                    --name ${CONTAINER_NAME} \
                    -p ${APP_PORT}:3000 \
                    --restart unless-stopped \
                    ${FULL_IMAGE_NAME}
                """
            }
        }

        stage('Docker Cleanup') {
            steps {
                sh 'docker image prune -f'
            }
        }
    }
}